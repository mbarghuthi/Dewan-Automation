-<+><html>\r\n<head>\r\n<title>stories.TC_006_UOP</title>\r\n<style type=\"text/css\" media=\"all\">\r\n@import url( \"./style/jbehave-core.css\" );\r\n</style>\r\n</head>\r\n<body>\r\n<div class=\"story\">\r\n<h1>&#65279;</h1>\r\n<div class=\"path\">stories/TC_006_UOP.story</div>\r\n<div class=\"scenario\">\r\n<h2>Scenario: TC_001_UOP UOP Create Incoming</h2>\r\n<div class=\"step successful\">Given  I navigate to 'http://172.16.30.82:8888/login.aspx'</div>\r\n<div class=\"step successful\">And  I login as 'alaa.abdelbagi' with password 'Aa1'</div>\r\n<div class=\"step successful\">And  I click on 'Add Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Incoming Button'</div>\r\n<div class=\"step successful\">When  Set 'Subject Field' value to 'random'</div>\r\n<div class=\"step successful\">And  Set 'Num Book From The Source' value to 'nanotime'</div>\r\n<div class=\"step successful\">And  I select '2 | &#1608;&#1581;&#1583;&#1577; &#1575;&#1604;&#1585;&#1602;&#1575;&#1576;&#1577;' from the 'Incoming Commissioner Destination' combo box</div>\r\n<div class=\"step successful\">And  I select '1 | &#1608;&#1586;&#1575;&#1585;&#1577; &#1575;&#1604;&#1578;&#1585;&#1576;&#1610;&#1577;' from the 'Source Book By Name' combo box</div>\r\n<div class=\"step successful\">And  I wait for '4' sec</div>\r\n<div class=\"step successful\">And  Select 'Head Of Artistic' value from 'Receiver Name'</div>\r\n<div class=\"step successful\">And  I wait for '4' sec</div>\r\n<div class=\"step successful\">And  I select '1578 | &#1575;&#1585;&#1575;&#1605;&#1603;&#1587;' from the 'Delivery' combo box</div>\r\n<div class=\"step successful\">And  I click on 'Save Draft Button'</div>\r\n<div class=\"step successful\">And  I click on 'Save Button'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I get value from 'Incoming Commissioner Destination' and save it as 'ComboBoxValue'</div>\r\n<div class=\"step successful\">And  I get text from 'Subject Field' and save it as 'SubjectText'</div>\r\n<div class=\"step successful\">And  I get value from 'Incoming Get Serial Number' and save it as 'IncomingSerialNumberValue'</div>\r\n<div class=\"step successful\">And  I click on 'Direction Button'</div>\r\n<div class=\"step successful\">And  Verify text of 'Department Liaison Officer Name' contains saved value 'ComboBoxValue'</div>\r\n<div class=\"step successful\">And  I click on 'Approve Button'</div>\r\n<div class=\"step successful\">And  I wait for '6' sec</div>\r\n<div class=\"step successful\">And  I click on 'My Processes List Header Button'</div>\r\n<div class=\"step successful\">And  Verify 'Process Status' equals '&#1578;&#1581;&#1578; &#1575;&#1604;&#1575;&#1580;&#1585;&#1575;&#1569;' text</div>\r\n<div class=\"step successful\">And  I click on 'View Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Incoming Users Directed To'</div>\r\n<div class=\"step successful\">And  Verify 'Incoming User Name Directed To1' equals 'audit1' text</div>\r\n<div class=\"step successful\">And  I click on 'Completed Tasks'</div>\r\n<div class=\"step successful\">And  Verify text of 'Completed Tasks First Subject Text' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  I click on 'logout Button'</div>\r\n<div class=\"step successful\">And  I login as 'audit1' with password 'Aa1'</div>\r\n<div class=\"step successful\">And  I click on 'Task List Header Button'</div>\r\n<div class=\"step successful\">And  Verify text of 'Task List First Subject Text' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  I click on 'View Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Direction Button'</div>\r\n<div class=\"step successful\">And  I wait for '5' sec</div>\r\n<div class=\"step successful\">And  I click on 'Close Button'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I accept alert</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I click on 'Completed Tasks'</div>\r\n<div class=\"step successful\">And  Verify text of 'Completed Tasks First Subject Text' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  I click on 'logout Button'</div>\r\n<div class=\"step successful\">And  Verify 'login Button' is present</div>\r\n<div class=\"step successful\">Then  I login as 'alaa.abdelbagi' with password 'Aa1'</div>\r\n<div class=\"step successful\">And  I click on 'My Processes List Header Button'</div>\r\n<div class=\"step successful\">And  Verify 'Process Status' equals '&#1578;&#1605;&#1578; &#1575;&#1604;&#1593;&#1605;&#1604;&#1610;&#1577; &#1576;&#1606;&#1580;&#1575;&#1581;' text</div>\r\n<div class=\"step successful\">And  I click on 'logout Button'</div>\r\n<div class=\"step successful\">And  Verify 'login Button' is present</div>\r\n<div class=\"step ignorable\">!-- tc002</div>\r\n</div>\r\n<div class=\"scenario\">\r\n<h2>Scenario: TC_002_UOP UOP Create Incoming To view</h2>\r\n<div class=\"step successful\">Given  I navigate to 'http://172.16.30.82:8888/login.aspx'</div>\r\n<div class=\"step successful\">And  I login as 'alaa.abdelbagi' with password 'Aa1'</div>\r\n<div class=\"step successful\">And  I click on 'Add Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Incoming Button'</div>\r\n<div class=\"step successful\">When  Set 'Subject Field' value to 'random'</div>\r\n<div class=\"step successful\">And  Set 'Num Book From The Source' value to 'nanotime'</div>\r\n<div class=\"step successful\">And  I select '2 | &#1608;&#1581;&#1583;&#1577; &#1575;&#1604;&#1585;&#1602;&#1575;&#1576;&#1577;' from the 'Incoming Commissioner Destination' combo box</div>\r\n<div class=\"step successful\">And  I select '1 | &#1608;&#1586;&#1575;&#1585;&#1577; &#1575;&#1604;&#1578;&#1585;&#1576;&#1610;&#1577;' from the 'Source Book By Name' combo box</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  Select 'Head Of Artistic' value from 'Receiver Name'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I select '1578 | &#1575;&#1585;&#1575;&#1605;&#1603;&#1587;' from the 'Delivery' combo box</div>\r\n<div class=\"step successful\">And  I click on 'Save Draft Button'</div>\r\n<div class=\"step successful\">And  I click on 'Save Button'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I get value from 'Incoming Commissioner Destination' and save it as 'ComboBoxValue'</div>\r\n<div class=\"step successful\">And  I get text from 'Subject Field' and save it as 'SubjectText'</div>\r\n<div class=\"step successful\">And  I get value from 'Incoming Get Serial Number' and save it as 'IncomingSerialNumberValue'</div>\r\n<div class=\"step successful\">And  I click on 'Direction Button'</div>\r\n<div class=\"step ignorable\">!-- And  Verify text of 'Department Liaison Officer Name' contains saved value 'ComboBoxValue'</div>\r\n<div class=\"step successful\">And  I click on 'Click On All Check Box'</div>\r\n<div class=\"step successful\">And  I click on 'Delete Button'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I click on 'Close Notification Button'</div>\r\n<div class=\"step successful\">And  I select '2 | &#1608;&#1581;&#1583;&#1577; &#1575;&#1604;&#1585;&#1602;&#1575;&#1576;&#1577;' from the 'Division Input' combo box</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I select the 'To View Radio Button'</div>\r\n<div class=\"step successful\">And  I wait for '3' sec</div>\r\n<div class=\"step successful\">And  I click on 'Add Button'</div>\r\n<div class=\"step successful\">And  I wait for '4' sec</div>\r\n<div class=\"step successful\">And  I click on 'Close Notification Button'</div>\r\n<div class=\"step successful\">And  I click on 'Approve Button'</div>\r\n<div class=\"step successful\">And  I wait for '4' sec</div>\r\n<div class=\"step successful\">And  I click on 'My Processes List Header Button'</div>\r\n<div class=\"step successful\">And  Verify 'Process Status' equals '&#1578;&#1605;&#1578; &#1575;&#1604;&#1593;&#1605;&#1604;&#1610;&#1577; &#1576;&#1606;&#1580;&#1575;&#1581;' text</div>\r\n<div class=\"step successful\">And  I click on 'View Process Button'</div>\r\n<div class=\"step successful\">And  I click on 'Incoming Users Directed To'</div>\r\n<div class=\"step successful\">And  Verify 'Incoming User Name Directed To1' equals 'audit1' text</div>\r\n<div class=\"step successful\">And  I click on 'Completed Tasks'</div>\r\n<div class=\"step successful\">And  Verify text of 'Completed Tasks First Subject Text' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  I click on 'logout Button'</div>\r\n<div class=\"step successful\">Then  I login as 'audit1' with password 'Aa1'</div>\r\n<div class=\"step successful\">And  I click on 'Tasks To View'</div>\r\n<div class=\"step successful\">And  Verify text of 'Tasks To View First Subject Text' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  I click on 'View Process Button'</div>\r\n<div class=\"step successful\">And  Verify text of 'Subject Field' equals saved value 'SubjectText'</div>\r\n<div class=\"step successful\">And  Verify value of 'Incoming Get Serial Number' equals saved value 'IncomingSerialNumberValue'</div>\r\n<div class=\"step successful\">And  I click on 'logout Button'</div>\r\n<div class=\"step successful\">And  Verify 'login Button' is present</div>\r\n</div>\r\n</div>\r\n\r\n</body>\r\n<!--  SyntaxHighlighter resources:  should be included at end of body -->\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./style/sh-3.0.83/shCore.css\"/>\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"./style/sh-3.0.83/shThemeRDark.css\"/>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shCore.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushBash.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushCss.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushDiff.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushGroovy.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushJava.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushJScript.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushPlain.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushPython.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushRuby.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushScala.js\"></script>\r\n<script language=\"javascript\" src=\"./js/sh-3.0.83/shBrushXml.js\"></script>\r\n<script language=\"javascript\" src=\"./js/shBrushBdd.js\"></script>\r\n<script type=\"text/javascript\">\r\n    SyntaxHighlighter.defaults['gutter'] = false;\r\n    SyntaxHighlighter.defaults['toolbar'] = false;    \r\n    SyntaxHighlighter.all();\r\n</script>\r\n</html>\r\n
